DEBUG=false
FILE_SERVER_NODE_URL=https://subdomain.your-domain.com/node
TZ=America/New_York
FFMPEG_CONCURRENCY=2

# Node
BASE_PATH=/path/to/media/files
LOG_PATH=/path/to/logs

PREFIX_PATH=/media

# System Status Monitoring Configuration

# Enable/disable specific resource monitoring
# Set to FALSE to disable monitoring for a specific resource type
# SYSTEM_STATUS_MONITOR_CPU=TRUE
# SYSTEM_STATUS_MONITOR_MEMORY=TRUE
# SYSTEM_STATUS_MONITOR_DISK=TRUE

# Custom threshold percentages for different status levels
# CPU thresholds (percentage)
# SYSTEM_STATUS_CPU_ELEVATED=70
# SYSTEM_STATUS_CPU_HEAVY=85
# SYSTEM_STATUS_CPU_CRITICAL=95

# Memory thresholds (percentage)
# SYSTEM_STATUS_MEMORY_ELEVATED=70
# SYSTEM_STATUS_MEMORY_HEAVY=80
# SYSTEM_STATUS_MEMORY_CRITICAL=90

# Disk thresholds (percentage)
# SYSTEM_STATUS_DISK_ELEVATED=80
# SYSTEM_STATUS_DISK_HEAVY=90
# SYSTEM_STATUS_DISK_CRITICAL=95

# Minimum free disk space in GB before triggering critical warning
# SYSTEM_STATUS_MIN_FREE_DISK_GB=5

# Frontend Webhook Configuration

# Multi-frontend approach
# Each frontend has its own webhook ID (supports unlimited frontends)
# FRONT_END_1=https://subdomain.your-domain.com
# WEBHOOK_ID_1=321f131x45912w4d9b8c1q1bbd76c9k
# FRONT_END_2=http://localhost:3232
# WEBHOOK_ID_2=o4jsi82ksjLowQ910PXosEas5S0eopqS
# FRONT_END_3=https://another-frontend.example.com
# WEBHOOK_ID_3=fafsa312OPswWQPOSnSLWeYoPX124123kWo
# Add more frontend/webhook pairs as needed (FRONT_END_4, WEBHOOK_ID_4, etc.)

# Better Auth
# Must match the Next.js app's BETTER_AUTH_SECRET exactly — sessions are validated
# against the shared MongoDB Users database using this secret for HMAC verification.
BETTER_AUTH_SECRET=your_better_auth_secret
BETTER_AUTH_URL=https://personalserver.your-domain.com

# Cross-domain cookie sharing (must match AUTH_COOKIE_DOMAIN in the Next.js app)
# When set, the session cookie issued by the Next.js app (Domain=<value>) will be
# accepted here automatically — no Bearer token needed for browser requests.
# Value should be the root domain WITHOUT a leading dot: "example.com"
AUTH_COOKIE_DOMAIN=

# MongoDB Connection
MONGODB_URI=mongodb://user:password@localhost:27017/mediadb
# Auth database — must point to the same DB the Next.js app writes sessions to
MONGODB_AUTH_DB=Users

# TMDB API Key
TMDB_API_KEY=your_tmdb_api_key_here

# *Optional*
# TMDB Metadata Refresh Intervals (in days)
# How often to refresh episode metadata files
EPISODE_METADATA_REFRESH_DAYS=4
# How often to refresh season poster images
SEASON_POSTER_REFRESH_DAYS=1
# How often to refresh episode thumbnail images
EPISODE_THUMBNAIL_REFRESH_DAYS=3

# Blurhash Worker Thread Configuration
# Number of worker threads for blurhash generation (offloads CPU-intensive operations)
# Minimum workers to keep idle for fast response times
BLURHASH_MIN_THREADS=1
# Maximum worker threads (leave headroom for Sharp's thread pool)
BLURHASH_MAX_THREADS=4
# Idle worker timeout in milliseconds (60 seconds default)
BLURHASH_IDLE_TIMEOUT=60000
# Task timeout in milliseconds (30 seconds default)
BLURHASH_TASK_TIMEOUT=30000
# Concurrency limit for download operations (works with worker pool)
BLURHASH_CONCURRENCY=4
# Image enhancement concurrency for TMDB responses
TMDB_IMAGES_ENHANCE_CONCURRENCY=6

# FFPROBE_BINARY (optional otherwise use typical linux path)
# Path to the ffprobe binary
FFPROBE_BINARY=/usr/bin/ffprobe

# Auto-Generated Captions (whisper.cpp)
# Feature is gated by app_config.settings { name: "autoCaptions" } — disabled by default.
# Defaults (no env override needed):
#   - WHISPER_BIN: "whisper-cli" (POSIX) or "whisper-cli.exe" (Windows), resolved via PATH.
#   - WHISPER_MODELS_DIR: ./whisper-models (relative to process cwd)
#   - CAPTIONS_TMP_DIR: ./cache/captions (relative to process cwd)
# Docker overrides these to absolute container paths via the Dockerfile.
# Set explicitly here only when running locally with the binary in a non-standard location.
# WHISPER_BIN=/usr/local/bin/whisper-cli
# WHISPER_MODELS_DIR=/usr/src/app/whisper-models
# CAPTIONS_TMP_DIR=/usr/src/app/node/cache/captions
# Per-user JIT trigger rate limit (default 10 jobs/hour). Reads of existing
# .auto.srt files are never rate-limited.
# CAPTIONS_RATE_LIMIT_PER_HOUR=10
# Where the scanner's stub-entry URLs point. Defaults to this processor's
# /api/captions/track route. Set to a Next.js (or any proxy) route if you want
# the player to hit a proxy first — path shape stays /movie/:title/:lang and
# /tv/:show/:lang/:season/:episode so the proxy can route on it.
# CAPTIONS_TRACK_URL_PREFIX=https://app.example.com/api/authenticated/subtitles

# Session Cache Configuration
# In-memory caching for authenticated sessions to reduce MongoDB load
# SESSION_CACHE_TTL_MS=120000              # Cache TTL in milliseconds (default: 2 minutes)
# SESSION_CACHE_MAX_SIZE=10000             # Maximum cached sessions (default: 10,000)
# SESSION_CACHE_CLEANUP_INTERVAL_MS=30000  # Cleanup interval (default: 30 seconds)
# SESSION_CACHE_STATS_INTERVAL_MS=60000    # Stats reporting interval (default: 1 minute)

# Cross-Domain Authentication Configuration
# The application now supports:
# 1. Authorization: Bearer <token> headers (recommended for cross-domain)
# 2. x-session-token: <token> headers
# 3. x-mobile-token: <token> headers  
# 4. Session cookies (for same-domain scenarios)
#
# For cross-domain setups (like cinema.yourserver.com -> anothersubdomain.yourserver.com):
# - Configure FRONT_END_* variables with your frontend domains
# - Use Authorization headers or x-session-token headers in your frontend
# - Session cookies will work automatically for same-domain setups
